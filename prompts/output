🚀 Quick Start
Frontend
# Just open in browser!
open integrationiq/index.html

# Or deploy to Vercel (drag & drop)
# Visit https://vercel.com

Backend
cd integrationiq/backend

# Install dependencies
npm install

# Configure environment
cp .env.example .env
# Edit .env with your API keys

# Start MongoDB & Redis
docker-compose up -d

# Run server
npm run dev

# Server running at http://localhost:3000