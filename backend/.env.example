# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/integrationiq
MONGODB_TEST_URI=mongodb://localhost:27017/integrationiq_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# IBM Watson (Optional - for IBM Integration Copilot)
IBM_WATSON_API_KEY=your-ibm-watson-api-key
IBM_WATSON_URL=https://api.us-south.assistant.watson.cloud.ibm.com

# Third-Party Service APIs
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

AIRTABLE_API_KEY=your-airtable-api-key

SENDGRID_API_KEY=your-sendgrid-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# CORS
CORS_ORIGIN=http://localhost:8080,https://integrationiq.vercel.app

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key

# Webhook
WEBHOOK_SECRET=your-webhook-secret-for-verification

# Feature Flags
ENABLE_AI_HEALING=true
ENABLE_MONITORING=true
ENABLE_ANALYTICS=true